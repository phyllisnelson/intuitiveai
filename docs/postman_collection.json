    {
      "name": "VMs",
      "item": [
        {
          "name": "List VMs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('returns paginated list', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('data');",
                  "    pm.expect(body.data).to.be.an('array');",
                  "    pm.expect(body).to.have.property('total');",
                  "    pm.expect(body).to.have.property('page');",
                  "    pm.expect(body).to.have.property('page_size');",
                  "});",
                  "pm.test('saves seeded VM IDs for action tests', () => {",
                  "    const body = pm.response.json();",
                  "    const activeVms = body.data.filter(v => v.status === 'ACTIVE');",
                  "    const shutoffVms = body.data.filter(v => v.status === 'SHUTOFF');",
                  "    // Always reset so stale values from previous runs don't persist.",
                  "    pm.collectionVariables.set('seeded_active_vm_1', '');",
                  "    pm.collectionVariables.set('seeded_active_vm_2', '');",
                  "    pm.collectionVariables.set('seeded_shutoff_vm', '');",
                  "    if (activeVms.length >= 1) {",
                  "        pm.collectionVariables.set('seeded_active_vm_1', activeVms[0].id);",
                  "        console.log('seeded_active_vm_1:', activeVms[0].id);",
                  "    }",
                  "    if (activeVms.length >= 2) {",
                  "        pm.collectionVariables.set('seeded_active_vm_2', activeVms[1].id);",
                  "        console.log('seeded_active_vm_2:', activeVms[1].id);",
                  "    }",
                  "    if (shutoffVms.length >= 1) {",
                  "        pm.collectionVariables.set('seeded_shutoff_vm', shutoffVms[0].id);",
                  "        console.log('seeded_shutoff_vm:', shutoffVms[0].id);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/vms?limit=50&offset=0",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "vms"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "offset",
                  "value": "0"
                },
                {
                  "key": "status",
                  "value": "ACTIVE",
                  "disabled": true
                },
                {
                  "key": "name",
                  "value": "test-vm",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Create VM",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 202 Accepted', () => pm.response.to.have.status(202));",
                  "pm.test('returns task_id and vm_id', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('data');",
                  "    pm.expect(body.data).to.have.property('task_id');",
                  "    pm.expect(body).to.have.property('meta');",
                  "    pm.expect(body.meta).to.have.property('vm_id');",
                  "});",
                  "pm.test('saves vm_id and task_id', () => {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('vm_id', body.meta.vm_id);",
                  "    pm.collectionVariables.set('task_id', body.data.task_id);",
                  "    console.log('Saved vm_id:', body.meta.vm_id);",
                  "    console.log('Saved task_id:', body.data.task_id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
