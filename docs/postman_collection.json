{
  "info": {
    "name": "VM Lifecycle API",
    "description": "Full test suite for the VM Lifecycle API.\n\nAuth: set `api_key` for X-API-Key, or set `bearer_token` for Keycloak OIDC Bearer auth. At least one must be configured on the server.\n\nBackground operations (create VM, delete VM, resize VM) are processed by the arq worker. In local/mock mode the mock service handles them in-process. Poll `GET /api/v1/tasks/{task_id}` to track completion.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "description": "Base URL of the running API"
    },
    {
      "key": "api_key",
      "value": "changeme",
      "description": "Value for the X-API-Key header (static key auth). Matches API_KEY in .env \u2014 update if you changed it."
    },
    {
      "key": "vm_id",
      "value": "",
      "description": "Populated automatically by the Create VM test"
    },
    {
      "key": "task_id",
      "value": "",
      "description": "Populated automatically by async operations"
    },
    {
      "key": "flavor_id",
      "value": "",
      "description": "Populated automatically by List Flavors test"
    },
    {
      "key": "image_id",
      "value": "",
      "description": "Populated automatically by List Images test"
    },
    {
      "key": "seeded_active_vm_1",
      "value": "",
      "description": "First ACTIVE VM \u2014 populated by List VMs. Used for Console URL and Reboot."
    },
    {
      "key": "seeded_active_vm_2",
      "value": "",
      "description": "Second ACTIVE VM \u2014 populated by List VMs. Used for Stop and Snapshot."
    },
    {
      "key": "seeded_shutoff_vm",
      "value": "",
      "description": "First SHUTOFF VM \u2014 populated by List VMs. Used for Start and Resize."
    }
  ],
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "key",
        "value": "X-API-Key"
      },
      {
        "key": "value",
        "value": "{{api_key}}"
      },
      {
        "key": "in",
        "value": "header"
      }
    ]
  },
  "item": [
    {
      "name": "Setup",
      "description": "Run once before all other requests to seed the mock with factory_boy data.\n\nSaves seeded_active_vm_1, seeded_active_vm_2, seeded_shutoff_vm, flavor_id, image_id.",
      "item": [
        {
          "name": "Seed Mock",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('saves seeded resource IDs', () => {",
                  "    const body = pm.response.json();",
                  "    const active = body.vms.active;",
                  "    const shutoff = body.vms.shutoff;",
                  "    if (active.length >= 1) pm.collectionVariables.set('seeded_active_vm_1', active[0]);",
                  "    if (active.length >= 2) pm.collectionVariables.set('seeded_active_vm_2', active[1]);",
                  "    if (shutoff.length >= 1) pm.collectionVariables.set('seeded_shutoff_vm', shutoff[0]);",
                  "    if (body.flavors.length > 0) pm.collectionVariables.set('flavor_id', body.flavors[0]);",
                  "    if (body.images.length > 0) pm.collectionVariables.set('image_id', body.images[0]);",
                  "    console.log('seeded_active_vm_1:', active[0]);",
                  "    console.log('seeded_active_vm_2:', active[1]);",
                  "    console.log('seeded_shutoff_vm:', shutoff[0]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/dev/seed",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "dev",
                "seed"
              ]
            }
          }
        }
      ]
    },
    {
