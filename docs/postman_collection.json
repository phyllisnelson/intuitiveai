    {
      "name": "Tasks",
      "item": [
        {
          "name": "Poll Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('task has required fields', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.data).to.have.property('task_id');",
                  "    pm.expect(body.data).to.have.property('status');",
                  "    pm.expect(['pending', 'running', 'success', 'failed'])",
                  "        .to.include(body.data.status);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
