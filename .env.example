# ─────────────────────────────────────────────────────────────────────────────
# VM API — Environment Configuration
# Copy to .env and fill in values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="VM Lifecycle API"
APP_VERSION="0.1.0"
LOG_LEVEL="INFO"                      # DEBUG | INFO | WARNING | ERROR
API_PORT=8000                         # Host-published port (container always listens on 8000)

# Static API key for request authentication (CI/CD / non-OIDC clients).
# At least one of API_KEY or KEYCLOAK_URL must be set — unauthenticated
# access is not permitted.
API_KEY=changeme

# ── Task store ────────────────────────────────────────────────────────────────
# Tasks are stored in Redis and survive restarts / multi-worker deployments.
REDIS_URL=redis://localhost:6379
TASK_TTL_SECONDS=86400            # 24 h — Redis keys expire automatically

# ── OpenStack ─────────────────────────────────────────────────────────────────
OPENSTACK_AUTH_URL=https://openstack.pfbenergy.internal:5000/v3
OPENSTACK_USERNAME=pfb-api-svc
OPENSTACK_PASSWORD=changeme
OPENSTACK_PROJECT_NAME=pfb-operations
OPENSTACK_PROJECT_DOMAIN_NAME=Default
OPENSTACK_USER_DOMAIN_NAME=Default
OPENSTACK_REGION_NAME=RegionOne

# Default network UUID used when no network is specified in a create request.
OPENSTACK_DEFAULT_NETWORK_ID=

# ── Keycloak / OIDC ───────────────────────────────────────────────────────────
# Set KEYCLOAK_URL to enable OIDC authentication via token introspection.
# Leave blank to use X-API-Key only.  At least one of KEYCLOAK_URL or API_KEY
# must be configured — unauthenticated access is not permitted.
# Local dev: http://localhost:8085 (started by make local-up)
# Production: https://keycloak.pfbenergy.internal
KEYCLOAK_URL=https://keycloak.pfbenergy.internal
KEYCLOAK_REALM=vm-api
KEYCLOAK_CLIENT_ID=vm-api
KEYCLOAK_CLIENT_SECRET=changeme
KEYCLOAK_READER_ROLE=vm-reader
KEYCLOAK_OPERATOR_ROLE=vm-operator

# Credentials used by scripts/get-token.sh to obtain a Bearer token.
# Not read by the API itself — only used by the helper script.
KEYCLOAK_USERNAME=alice
KEYCLOAK_PASSWORD=changeme
